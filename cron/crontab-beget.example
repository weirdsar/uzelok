# Планировщик Beget (панель хостинга → «Cron» / «Задачи по расписанию»).
# На SSH по умолчанию может быть PHP 5.6 — для проекта нужен PHP 8.4:
#
# 0 3 * * * /usr/local/bin/php8.4 /home/ЛОГИН/uzelok64.ru/cron/sync.php >> /home/ЛОГИН/uzelok64.ru/logs/cron.log 2>&1
#
# Замените ЛОГИН на ваш (например weirds1w). Время 03:00 — как в README; поменяйте при необходимости.
