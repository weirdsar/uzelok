{
    "name": "uzelok/uzelok64",
    "description": "uzelok64.ru — multi-brand showcase + workshop",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-curl": "*",
        "ext-session": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64"
    },
    "autoload": {
        "psr-4": {
            "Uzelok\\Core\\Model\\": "core/Model/",
            "Uzelok\\Core\\Service\\": "core/Service/",
            "Uzelok\\Core\\Controller\\": "core/Controller/",
            "Uzelok\\Core\\": "core/"
        },
        "files": [
            "core/helpers.php"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
