# Скопируйте в .env (файл в .gitignore). Можно скопировать целиком из analitika/metrica-yandex/.env
# и заменить только YANDEX_COUNTER_ID на 108717789.

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_ACCESS_TOKEN=
YANDEX_COUNTER_ID=108717789

# Для создания целей через Management API обязательно:
YANDEX_OAUTH_SCOPE=metrika:read metrika:write
